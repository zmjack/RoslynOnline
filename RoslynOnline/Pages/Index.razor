@page "/"

<div id="container" style="width:1024px;height:600px;border:1px solid grey"></div>
<button class="btn" @onclick="Run">Run</button>
<button class="btn" onclick="hello()"> Hello </button>
<br />
<textarea @bind="Output" rows="10" cols="120"></textarea>


<script>
		async function hello() {
			const result = await DotNet.invokeMethodAsync('CompilerApp', 'RunCode', `using System;

	class Program
	{
		public static void Main()
		{
			Console.WriteLine("Hello World");
		}
	}`);
	console.log(result);
		}
</script>
